# Worker stack environment (docker-compose.worker.yml). Copy to .env next to that file.
# See docs/PLANNING_multi_instance.md, Component 4.

# wss:// endpoint of the cloud app's /agent WebSocket control plane.
APP_URL=wss://mediator.example.com/agent

# Shared secret validated at WebSocket handshake. Must match the cloud app's AGENT_TOKEN.
AGENT_TOKEN=

# Unique name for this physical location, e.g. "shop" or "warehouse".
INSTANCE_ID=

# CUPS host[:port] this agent prints through. Defaults to the bundled `cups` service in
# docker-compose.worker.yml (port 631). Point this at an existing CUPS server instead (e.g. a
# Raspberry Pi running docs/detailed/printer-server-setup.md) to skip the bundled container —
# just delete the `cups` service block from docker-compose.worker.yml and set this to that
# server's reachable hostname or IP, e.g. CUPS_HOST=printserver.local
# CUPS_HOST=cups

# Comma-separated CUPS queue names this agent reports in its `hello` message, e.g.
# AGENT_QUEUES=QL800_item,QL800_box
AGENT_QUEUES=
