{
  "name": "mediator-service",
  "version": "3.0.0",
  "private": true,
  "scripts": {
    "prebuild": "node scripts/prebuild.js",
    "build": "tsc -p tsconfig.json && npm run bundle && node scripts/build.js",
    "bundle": "node frontend/bundle.js",
    "prestart": "npm run build",
    "start": "node dist/backend/server.js",
    "test": "npm run prebuild && node scripts/run-tests.js",
    "smoke": "ts-node --transpile-only scripts/smoke-server.ts",
    "migrate": "node scripts/migrate-sqlite-to-postgres.js"
  },
  "dependencies": {
    "@langchain/ollama": "^1.0.0",
    "@langchain/openai": "^1.0.0",
    "@tavily/core": "^0.5.12",
    "@types/pg": "^8.20.0",
    "@types/string-similarity": "^4.0.2",
    "better-sqlite3": "^9.4.0",
    "chokidar": "^3.6.0",
    "csv-parse": "^5.5.6",
    "dotenv": "^16.4.5",
    "esbuild": "^0.25.10",
    "pdfkit": "^0.17.1",
    "pg": "^8.21.0",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^5.5.0",
    "react-router-dom": "^6.23.0",
    "sass": "^1.92.0",
    "string-similarity": "^4.0.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^29.5.6",
    "@types/node": "^20.19.41",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/react-router-dom": "^5.3.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.4.1",
    "ts-jest": "^29.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  }
}
